# GitLab
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
SOURCE_TYPE=group
SOURCE_PATH=my-group

# Auth method: "ldap" or "oidc"
AUTH_METHOD=ldap

# Comma-separated usernames that get admin role (all others are viewers)
ADMIN_USERS=admin,jdoe

# ── LDAP (when AUTH_METHOD=ldap) ──
LDAP_URL=ldap://localhost:389
LDAP_BIND_DN=uid={{username}},ou=people,dc=example,dc=com

# ── OIDC (when AUTH_METHOD=oidc) ──
# OIDC_ISSUER_URL=https://auth.example.com/realms/myrealm
# OIDC_CLIENT_ID=glance
# OIDC_CLIENT_SECRET=your-client-secret
# OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# OIDC_USERNAME_CLAIM=preferred_username
# SESSION_SECRET=random-secret-for-cookie-signing

# Server
PORT=3000
